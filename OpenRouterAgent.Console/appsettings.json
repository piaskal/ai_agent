{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "OpenRouterAgent.ConsoleApp.OpenRouter.OpenRouterClient": "Trace"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": { "restrictedToMinimumLevel": "Warning" }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/trace-.log",
          "rollingInterval": "Day"
        }
      }
    ]
  },
  "OpenRouter": {
    "BaseUrl": "https://openrouter.ai/",
    "ApiKey": "",
    "Model": "openai/gpt-4o-mini",
    "SystemPrompt": "You are a concise and reliable AI assistant. Ask clarifying questions only when necessary and prefer actionable answers.",
    "Temperature": 0.2,
    "MaxTokens": 512,
    "AppName": "OpenRouterAgent.Console",
    "AppUrl": ""
  }
}