{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "OpenRouterAgent.ConsoleApp.OpenRouter.OpenRouterClient": "Verbose",
        "OpenRouterAgent.ConsoleApp.Agent.Tools.Electricity.DescribeConnectionMapTool": "Verbose",
        "OpenRouterAgent.ConsoleApp.Agent.Tools.SaveThem": "Debug"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": { "restrictedToMinimumLevel": "Debug" }
      }
    ]
  },
  "OpenRouter": {
    "Provider": "llmrouter",
    "OpenRouterBaseUrl": "https://openrouter.ai/",
    "LlmRouterBaseUrl": "https://llmrouter.gft.com/openai/v1/",
    "BaseUrl": "",
    "ApiKey": "",
    "Model": "gpt-5.1",
    "ToolModel": "gpt-5-mini",
    "SystemPrompt": "You are an agent of the OKO system, perform actions requested by user. Use the tools at your disposal to gather information and complete tasks. Always think step by step and use the tools when needed.",
    "MaxTokens": 6048,
    "AppName": "OpenRouterAgent.Console",
    "AppUrl": ""
  },
  "LlmRouter": {
    "ApiKey": ""
  },
  "AgentTools": {
    "EnableTools": true,
    "EnabledTools": ["oko_editor","oko_browse"],
    "DisabledTools": []
    
  }
}