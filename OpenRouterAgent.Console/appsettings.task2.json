{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "OpenRouterAgent.ConsoleApp.OpenRouter.OpenRouterClient": "Verbose"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": { "restrictedToMinimumLevel": "Information" }
      }
    ]
  },
  "OpenRouter": {
    "BaseUrl": "https://openrouter.ai/",
    "ApiKey": "",
    "Model": "openai/gpt-5-mini",
    "SystemPrompt": "You are a concise and reliable AI assistant. Ask clarifying questions only when necessary and prefer actionable answers.",
    "Temperature": 0.2,
    "MaxTokens": 6048,
    "AppName": "OpenRouterAgent.Console",
    "AppUrl": ""
  },
  "AgentTools": {
    "EnableTools": true,
    "EnabledTools": ["get_suspects","get_suspect_locations","get_suspect_access_level","get_powerplant_locations","distance_between_locations"],
    "DisabledTools": []
  }
}